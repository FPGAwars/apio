{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${fileDirname}"
        },
        {
            "name": "Apio run command",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/apio/__main__.py",
            "args": [
                "build"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "cwd": "${workspaceFolder}/ledon",
            "subProcess": false
        },
        {
            "name": "Apio run test",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "-s",
                "-vv",
                "test/unit_tests/utils/test_usb_util.py::test_device_summaries"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "cwd": "${workspaceFolder}",
            "subProcess": false
        },
        {
            "name": "Apio Scons remote debugger",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "localhost",
                "port": 5678
            },
            "justMyCode": false,
            "subProcess": false
        },
        {
            "name": "Debug SConstruct",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/.venv/bin/scons",
            "args": [
                "-f", "${workspaceFolder}/apio/scons/SConstruct",
                "build",
                "params=${workspaceFolder}/ledon/_build/default/scons.params",
                "timestamp=02180043484"
                
                //"--directory=${workspaceFolder}/apio/scons",
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "cwd": "${workspaceFolder}/ledon",
        }
    ]
}
